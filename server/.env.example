PORT=5000
NODE_ENV=development

# ── Supabase ──────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API

# Your project URL (e.g. https://abcdefgh.supabase.co)
SUPABASE_URL=https://your-project-id.supabase.co

# service_role key — has admin access, NEVER expose to frontend
SUPABASE_SERVICE_KEY=your_service_role_key_here

# anon/public key — safe to expose, respects RLS
SUPABASE_ANON_KEY=your_anon_public_key_here

# ── App ───────────────────────────────────────────────────────
# URL of your frontend (for CORS and password reset redirect)
CLIENT_URL=http://localhost:5173
